# Copy to `.env` and fill in your values:
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Your OpenAI key will be visible in built client JS — use a backend proxy
# for production if that is a concern.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_PUBLIC=your_supabase_anon_public_key

# OpenAI — API keys at https://platform.openai.com/api-keys
# Chat Completions endpoint used by the translate feature:
VITE_OPEN_AI_URL=https://api.openai.com/v1/chat/completions
VITE_OPEN_AI_KEY=sk-your_openai_api_key
